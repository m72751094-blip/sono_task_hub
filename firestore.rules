rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Helpers ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'fullName', 'email', 'balance', 'totalEarnings', 'completedTasks', 'role', 'createdAt'])
          && data.keys().size() == 8
          && data.uid == request.auth.uid
          && data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 100
          && data.email is string && data.email.size() <= 200
          && data.balance is number && data.balance >= 0
          && data.totalEarnings is number && data.totalEarnings >= 0
          && data.completedTasks is int && data.completedTasks >= 0
          && data.role in ['user', 'admin']
          && (data.role == 'user' || data.email == 'm72751094@gmail.com' || isAdmin()) 
          && data.createdAt == request.time;
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['userId', 'taskId', 'status', 'rewardAmount', 'createdAt'])
          && data.userId == request.auth.uid
          && data.status == 'pending'
          && data.rewardAmount is number
          && data.createdAt == request.time;
    }

    function isValidWithdrawal(data) {
      return data.keys().hasAll(['userId', 'amount', 'method', 'accountDetails', 'status', 'createdAt'])
          && data.userId == request.auth.uid
          && data.amount is number && data.amount >= 500
          && data.method in ['JazzCash', 'Easypaisa', 'Bank Account']
          && data.status == 'pending'
          && data.createdAt == request.time;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'authorName', 'content', 'createdAt'])
          && data.authorId == request.auth.uid
          && data.content is string && data.content.size() > 0 && data.content.size() <= 2000
          && data.createdAt == request.time;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['postId', 'userId', 'userName', 'content', 'createdAt'])
          && data.userId == request.auth.uid
          && data.content is string && data.content.size() > 0 && data.content.size() <= 500
          && data.createdAt == request.time;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidUser(incoming());
      allow update: if isAdmin() || (
        isOwner(userId) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['fullName'])
        && incoming().fullName is string && incoming().fullName.size() > 0
      );
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /taskSubmissions/{submissionId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (request.query.limit <= 100 && (isAdmin() || resource.data.userId == request.auth.uid));
      allow create: if isSignedIn() && isValidSubmission(incoming());
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasAll(['status'])
      );
    }

    match /withdrawals/{withdrawalId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (request.query.limit <= 100 && (isAdmin() || resource.data.userId == request.auth.uid));
      allow create: if isSignedIn() && isValidWithdrawal(incoming())
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.balance >= incoming().amount;
      allow update: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow list: if (isSignedIn() && existing().status == 'approved') || isAdmin();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().status == 'pending';
      allow update: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userId == 'all');
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || existing().userId == 'all');
      allow create: if isAdmin();
      allow update: if isSignedIn() && isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }

    match /communityPosts/{postId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidPost(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /communityComments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidComment(incoming());
      allow delete: if isAdmin() || isOwner(existing().userId);
    }
  }
}
